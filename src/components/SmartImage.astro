---
/**
 * Image with a built-in forest-gradient fallback.
 * If the photo fails to load, the gradient remains — the layout never breaks.
 */
interface Props {
  src: string;
  alt: string;
  class?: string;
  loading?: "lazy" | "eager";
  sizes?: string;
}
const { src, alt, class: className = "", loading = "lazy" } = Astro.props;
---

<div
  class:list={[
    "relative overflow-hidden bg-gradient-to-br from-forest-700 via-forest-800 to-forest-950",
    className,
  ]}
>
  <img
    src={src}
    alt={alt}
    loading={loading}
    decoding="async"
    class="h-full w-full object-cover"
    onerror="this.style.opacity='0'"
  />
</div>
