---
import SmartImage from "./SmartImage.astro";

interface Props {
  href: string;
  title: string;
  priceLabel: string;
  category: string;
  status: string;
  acreage: number;
  address: string;
  zoning?: string;
  image: string;
  imageAlt: string;
}
const {
  href,
  title,
  priceLabel,
  category,
  status,
  acreage,
  address,
  zoning,
  image,
  imageAlt,
} = Astro.props;
---

<a
  href={href}
  class="group relative flex flex-col overflow-hidden rounded-2xl border border-sand bg-white shadow-[0_10px_30px_-18px_rgba(40,30,10,0.45)] transition-all duration-500 hover:-translate-y-1.5 hover:shadow-[0_28px_60px_-28px_rgba(40,30,10,0.55)]"
>
  <div class="relative aspect-[4/3] overflow-hidden">
    <SmartImage
      src={image}
      alt={imageAlt}
      class="h-full w-full transition-transform duration-[1.2s] ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-105"
    />
    <!-- category badge -->
    <span
      class="eyebrow absolute left-3 top-3 rounded-md bg-forest-900/90 px-2.5 py-1.5 text-gold-500 backdrop-blur-sm"
      >{category}</span
    >
    {
      status !== "Available" && (
        <span class="eyebrow absolute right-3 top-3 rounded-md bg-terra-500 px-2.5 py-1.5 text-cream">
          {status}
        </span>
      )
    }
  </div>

  <div class="flex flex-1 flex-col p-5 sm:p-6">
    <div class="font-display text-2xl font-semibold text-ink">{priceLabel}</div>
    <h3 class="mt-1.5 font-sans text-base font-semibold leading-snug text-forest-800">
      {title}
    </h3>
    <p class="mt-1 text-sm text-stone">{address}</p>

    <div class="mt-auto flex flex-wrap gap-x-5 gap-y-1 pt-5 text-sm text-stone">
      <span><b class="font-semibold text-forest-700">{acreage}</b> acres</span>
      {zoning && <span><b class="font-semibold text-forest-700">{zoning}</b> zoning</span>}
    </div>

    <span
      class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-terra-500"
    >
      View property
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-1">
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </span>
  </div>
</a>
