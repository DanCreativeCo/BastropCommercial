---
import { site } from "../lib/site";
import SmartImage from "./SmartImage.astro";

const heroImage =
  "https://images.unsplash.com/photo-1500382017468-9049fed747ef?w=1920&q=72&auto=format&fit=crop";
---

<section class="relative isolate min-h-[88vh] overflow-hidden bg-forest-900">
  <!-- Cinematic backdrop -->
  <SmartImage
    src={heroImage}
    alt="Golden-hour view of open Central Texas land along a growth corridor"
    loading="eager"
    class="absolute inset-0 -z-10 h-full w-full"
  />
  <div class="scrim-hero absolute inset-0 -z-10"></div>
  <!-- gold horizon glow -->
  <div
    class="pointer-events-none absolute -right-32 top-10 -z-10 h-[420px] w-[420px] rounded-full opacity-40 blur-3xl"
    style="background: radial-gradient(circle, rgba(202,162,74,0.5), transparent 65%);"
  >
  </div>

  <div class="mx-auto flex min-h-[88vh] max-w-7xl flex-col justify-end px-5 pb-12 pt-32 sm:px-8 lg:pb-16">
    <div class="max-w-3xl">
      <span class="eyebrow reveal block text-gold-500" style="animation-delay:.05s">
        Bastrop County · Central Texas
      </span>
      <h1
        class="reveal mt-5 font-display text-[3rem] font-medium leading-[0.98] tracking-tight text-cream sm:text-7xl lg:text-[5.25rem]"
        style="animation-delay:.15s"
      >
        Where Texas<br />builds next.
      </h1>
      <p
        class="reveal mt-6 max-w-xl text-base leading-relaxed text-cream/85 sm:text-lg"
        style="animation-delay:.28s"
      >
        {site.description}
      </p>
      <div class="reveal mt-9 flex flex-wrap gap-3" style="animation-delay:.4s">
        <a href="/listings" class="btn btn-gold">Explore Listings</a>
        <a href="/contact" class="btn btn-ghost">Book a Consultation</a>
      </div>
    </div>

    <!-- Trust stat strip -->
    <div
      class="reveal mt-14 grid grid-cols-2 gap-px overflow-hidden rounded-2xl border border-cream/15 bg-cream/5 backdrop-blur-sm sm:grid-cols-4"
      style="animation-delay:.55s"
    >
      {
        site.stats.map((stat) => (
          <div class="bg-forest-900/30 px-5 py-6">
            <div class="font-display text-2xl font-semibold text-cream sm:text-3xl">
              {stat.value}
            </div>
            <div class="eyebrow mt-1.5 text-cream/55">{stat.label}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>
