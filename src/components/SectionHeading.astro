---
interface Props {
  eyebrow?: string;
  title: string;
  align?: "left" | "center";
  tone?: "dark" | "light"; // dark = for light backgrounds, light = for dark backgrounds
}
const { eyebrow, title, align = "left", tone = "dark" } = Astro.props;
---

<div class:list={[align === "center" && "text-center"]}>
  {
    eyebrow && (
      <span
        class:list={[
          "eyebrow block",
          tone === "dark" ? "text-terra-500" : "text-gold-500",
        ]}
      >
        {eyebrow}
      </span>
    )
  }
  <h2
    class:list={[
      "mt-3 font-display text-3xl font-medium leading-[1.05] sm:text-4xl md:text-[2.75rem]",
      tone === "dark" ? "text-ink" : "text-cream",
    ]}
  >
    {title}
  </h2>
  <slot />
</div>
