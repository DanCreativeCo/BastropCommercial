---
import "../styles/global.css";

/* ───────────────────────────────────────────────────────────
   Bastrop Commercial Real Estate — single static landing page.
   Everything (content, markup, styles, scripts) lives here so the
   page builds to one self-contained static HTML document.
   ─────────────────────────────────────────────────────────── */

const site = {
  name: "Bastrop Commercial",
  longName: "Bastrop Commercial Real Estate",
  tagline: "Where Texas builds next.",
  description:
    "Investment land, development sites, and commercial property in Bastrop County, Texas — represented with institutional rigor and local conviction.",
  agent: {
    name: "Taylor Homuth",
    title: "Realtor®",
    brokerage: "Spyglass Realty",
    phone: "512-877-6292",
    phoneHref: "tel:+15128776292",
    email: "taylor@spyglassrealty.com",
    bio: "Taylor is a Bastrop County commercial specialist who pairs institutional-grade diligence with genuine local conviction. Having spent the majority of her life on a ranch, she brings a rare, grounded understanding of land to every transaction — guiding investors, developers, and business owners through deals built on trust, clarity, and follow-through.",
  },
};

const stats = [
  { value: "$25M+", label: "Active Inventory" },
  { value: "90+ ac", label: "Industrial Land" },
  { value: "Bastrop", label: "County Specialist" },
  { value: "20 min", label: "To Austin (ABIA)" },
];

const nav = [
  { label: "About", href: "#about" },
  { label: "Listings", href: "#listings" },
  { label: "Buy / Sell", href: "#buy-sell" },
  { label: "Agent", href: "#agent" },
  { label: "Contact", href: "#contact" },
];

const listings = [
  {
    title: "88.8 Acres — Industrial Development Tract",
    priceLabel: "$22,900,000",
    category: "Industrial",
    status: "Available",
    acreage: 88.8,
    address: "SH-71 Corridor, Bastrop, TX 78602",
    zoning: "Industrial",
    image:
      "https://images.unsplash.com/photo-1628744448840-55bdb3c1aad1?w=1400&q=72&auto=format&fit=crop",
    imageAlt:
      "Aerial view of expansive industrial development land along a highway corridor",
  },
  {
    title: "1.79 Acres — Highway Commercial Corner",
    priceLabel: "$1,800,000",
    category: "Commercial",
    status: "Available",
    acreage: 1.79,
    address: "Highway Frontage, Bastrop, TX 78602",
    zoning: "Commercial",
    image:
      "https://images.unsplash.com/photo-1466692476868-aef1dfb1e735?w=1400&q=72&auto=format&fit=crop",
    imageAlt: "Open commercial land parcel near a Texas highway at golden hour",
  },
  {
    title: "1.15 Acres — P5 Mixed-Use Lot",
    priceLabel: "$450,000",
    category: "Development Land",
    status: "Available",
    acreage: 1.15,
    address: "Downtown-Adjacent, Bastrop, TX 78602",
    zoning: "P5 (Mixed-Use)",
    image:
      "https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=1400&q=72&auto=format&fit=crop",
    imageAlt: "Gently rolling mixed-use development lot in a Texas town",
  },
];

const heroImage =
  "https://images.unsplash.com/photo-1500382017468-9049fed747ef?w=1920&q=72&auto=format&fit=crop";
const countyImage =
  "https://images.unsplash.com/photo-1426604966848-d7adac402bff?w=1200&q=72&auto=format&fit=crop";
const agentImage =
  "https://images.unsplash.com/photo-1551836022-deb4988cc6c0?w=900&q=72&auto=format&fit=crop";

const fullTitle = `${site.longName} — ${site.tagline}`;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={site.description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={site.description} />
    <meta property="og:site_name" content={site.longName} />
    <meta name="theme-color" content="#16291c" />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:rounded-md focus:bg-forest-800 focus:px-4 focus:py-2 focus:text-cream"
      >Skip to content</a
    >

    <!-- HEADER ─────────────────────────────────────────────── -->
    <header class="site-header fixed inset-x-0 top-0 z-40 text-cream transition-all duration-500">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4 sm:px-8">
        <a href="#main" class="group flex items-center gap-2.5">
          <span
            class="grid h-9 w-9 place-items-center rounded-md bg-gold-500 font-display text-lg font-semibold text-forest-950 transition-transform duration-300 group-hover:-rotate-6"
            >B</span
          >
          <span class="font-display text-[1.05rem] font-semibold tracking-tight">{site.name}</span>
        </a>

        <nav class="hidden items-center gap-7 lg:flex" aria-label="Primary">
          {
            nav.map((item) => (
              <a href={item.href} class="link-underline text-sm font-medium">
                {item.label}
              </a>
            ))
          }
          <a href={site.agent.phoneHref} class="btn btn-gold text-sm">{site.agent.phone}</a>
        </nav>

        <button
          id="menu-toggle"
          class="lg:hidden"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
            <line x1="3" y1="7" x2="21" y2="7"></line>
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="17" x2="21" y2="17"></line>
          </svg>
        </button>
      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="fixed inset-0 z-50 hidden bg-forest-900 text-cream">
        <div class="flex items-center justify-between px-5 py-4 sm:px-8">
          <span class="font-display text-lg font-semibold">{site.name}</span>
          <button id="menu-close" aria-label="Close menu">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
              <line x1="6" y1="6" x2="18" y2="18"></line>
              <line x1="18" y1="6" x2="6" y2="18"></line>
            </svg>
          </button>
        </div>
        <nav class="flex flex-col gap-1 px-5 pt-6 sm:px-8" aria-label="Mobile">
          {
            nav.map((item) => (
              <a href={item.href} class="border-b border-forest-700/60 py-4 font-display text-2xl">
                {item.label}
              </a>
            ))
          }
          <a href={site.agent.phoneHref} class="btn btn-gold mt-8 justify-center text-base">
            Call {site.agent.phone}
          </a>
        </nav>
      </div>
    </header>

    <main id="main">
      <!-- HERO ─────────────────────────────────────────────── -->
      <section class="relative isolate min-h-[88vh] overflow-hidden bg-forest-900">
        <div class="absolute inset-0 -z-10 overflow-hidden bg-gradient-to-br from-forest-700 via-forest-800 to-forest-950">
          <img
            src={heroImage}
            alt="Golden-hour view of open Central Texas land along a growth corridor"
            loading="eager"
            decoding="async"
            class="h-full w-full object-cover"
            onerror="this.style.opacity='0'"
          />
        </div>
        <div class="scrim-hero absolute inset-0 -z-10"></div>
        <div
          class="pointer-events-none absolute -right-32 top-10 -z-10 h-[420px] w-[420px] rounded-full opacity-40 blur-3xl"
          style="background: radial-gradient(circle, rgba(202,162,74,0.5), transparent 65%);"
        >
        </div>

        <div class="mx-auto flex min-h-[88vh] max-w-7xl flex-col justify-end px-5 pb-12 pt-32 sm:px-8 lg:pb-16">
          <div class="max-w-3xl">
            <span class="eyebrow reveal block text-gold-500" style="animation-delay:.05s">
              Bastrop County · Central Texas
            </span>
            <h1
              class="reveal mt-5 font-display text-[3rem] font-medium leading-[0.98] tracking-tight text-cream sm:text-7xl lg:text-[5.25rem]"
              style="animation-delay:.15s"
            >
              Where Texas<br />builds next.
            </h1>
            <p
              class="reveal mt-6 max-w-xl text-base leading-relaxed text-cream/85 sm:text-lg"
              style="animation-delay:.28s"
            >
              {site.description}
            </p>
            <div class="reveal mt-9 flex flex-wrap gap-3" style="animation-delay:.4s">
              <a href="#listings" class="btn btn-gold">Explore Listings</a>
              <a href="#contact" class="btn btn-ghost">Book a Consultation</a>
            </div>
          </div>

          <div
            class="reveal mt-14 grid grid-cols-2 gap-px overflow-hidden rounded-2xl border border-cream/15 bg-cream/5 backdrop-blur-sm sm:grid-cols-4"
            style="animation-delay:.55s"
          >
            {
              stats.map((stat) => (
                <div class="bg-forest-900/30 px-5 py-6">
                  <div class="font-display text-2xl font-semibold text-cream sm:text-3xl">
                    {stat.value}
                  </div>
                  <div class="eyebrow mt-1.5 text-cream/55">{stat.label}</div>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <!-- ABOUT BASTROP COUNTY ─────────────────────────────── -->
      <section id="about" class="relative overflow-hidden bg-paper py-20 lg:py-28">
        <div class="mx-auto grid max-w-7xl items-center gap-12 px-5 sm:px-8 lg:grid-cols-2 lg:gap-20">
          <div class="relative">
            <div class="aspect-[4/5] w-full overflow-hidden rounded-2xl bg-gradient-to-br from-forest-700 via-forest-800 to-forest-950 shadow-[0_30px_60px_-30px_rgba(40,30,10,0.5)]">
              <img
                src={countyImage}
                alt="Rolling Central Texas landscape near Bastrop"
                loading="lazy"
                decoding="async"
                class="h-full w-full object-cover"
                onerror="this.style.opacity='0'"
              />
            </div>
            <div class="absolute -bottom-6 -right-4 hidden rounded-xl bg-forest-800 px-6 py-5 text-cream shadow-xl sm:block lg:-right-8">
              <div class="font-display text-3xl font-semibold text-gold-500">#1</div>
              <div class="eyebrow mt-1 max-w-[10ch] text-cream/70">Fastest-growing TX corridor</div>
            </div>
          </div>

          <div>
            <span class="eyebrow block text-terra-500">About Bastrop County</span>
            <h2 class="mt-3 font-display text-3xl font-medium leading-[1.05] text-ink sm:text-4xl md:text-[2.75rem]">
              A pro-growth county in Austin's path.
            </h2>
            <p class="mt-6 text-lg leading-relaxed text-stone">
              Bastrop County pairs a business-friendly posture with real, developable land —
              minutes from Austin-Bergstrom, Tesla, and the eastward expansion remaking
              Central Texas. For investors and developers, it's a rare window:
              <strong class="text-ink">availability, access, and appreciation in one market.</strong>
            </p>

            <ul class="mt-8 grid gap-4 sm:grid-cols-2">
              {[
                ["Highway-served", "SH-71 corridor to Austin & ABIA"],
                ["Developable", "Large, contiguous, properly-zoned tracts"],
                ["Pro-business", "Favorable zoning & incentives"],
                ["Appreciating", "Multi-year absorption tailwind"],
              ].map(([h, d]) => (
                <li class="rounded-xl border border-sand bg-white/60 p-5">
                  <div class="font-display text-lg font-semibold text-forest-800">{h}</div>
                  <div class="mt-1 text-sm text-stone">{d}</div>
                </li>
              ))}
            </ul>

            <a href="#listings" class="btn btn-forest mt-9">Start your search</a>
          </div>
        </div>
      </section>

      <!-- FEATURED LISTINGS ────────────────────────────────── -->
      <section id="listings" class="relative overflow-hidden bg-cream py-20 lg:py-28">
        <div class="mx-auto max-w-7xl px-5 sm:px-8">
          <div class="flex flex-wrap items-end justify-between gap-6">
            <div>
              <span class="eyebrow block text-terra-500">Featured Listings</span>
              <h2 class="mt-3 font-display text-3xl font-medium leading-[1.05] text-ink sm:text-4xl md:text-[2.75rem]">
                Land worth building on.
              </h2>
            </div>
            <a href="#contact" class="link-underline mb-1 text-sm font-semibold text-terra-500">
              Inquire about availability →
            </a>
          </div>

          <div class="mt-12 grid gap-7 sm:grid-cols-2 lg:grid-cols-3">
            {
              listings.map((l) => (
                <a
                  href="#contact"
                  class="group relative flex flex-col overflow-hidden rounded-2xl border border-sand bg-white shadow-[0_10px_30px_-18px_rgba(40,30,10,0.45)] transition-all duration-500 hover:-translate-y-1.5 hover:shadow-[0_28px_60px_-28px_rgba(40,30,10,0.55)]"
                >
                  <div class="relative aspect-[4/3] overflow-hidden bg-gradient-to-br from-forest-700 via-forest-800 to-forest-950">
                    <img
                      src={l.image}
                      alt={l.imageAlt}
                      loading="lazy"
                      decoding="async"
                      class="h-full w-full object-cover transition-transform duration-[1.2s] ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-105"
                      onerror="this.style.opacity='0'"
                    />
                    <span class="eyebrow absolute left-3 top-3 rounded-md bg-forest-900/90 px-2.5 py-1.5 text-gold-500 backdrop-blur-sm">
                      {l.category}
                    </span>
                    {l.status !== "Available" && (
                      <span class="eyebrow absolute right-3 top-3 rounded-md bg-terra-500 px-2.5 py-1.5 text-cream">
                        {l.status}
                      </span>
                    )}
                  </div>

                  <div class="flex flex-1 flex-col p-5 sm:p-6">
                    <div class="font-display text-2xl font-semibold text-ink">{l.priceLabel}</div>
                    <h3 class="mt-1.5 font-sans text-base font-semibold leading-snug text-forest-800">
                      {l.title}
                    </h3>
                    <p class="mt-1 text-sm text-stone">{l.address}</p>

                    <div class="mt-auto flex flex-wrap gap-x-5 gap-y-1 pt-5 text-sm text-stone">
                      <span><b class="font-semibold text-forest-700">{l.acreage}</b> acres</span>
                      {l.zoning && (
                        <span><b class="font-semibold text-forest-700">{l.zoning}</b> zoning</span>
                      )}
                    </div>

                    <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-terra-500">
                      Inquire
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-1">
                        <line x1="5" y1="12" x2="19" y2="12" />
                        <polyline points="12 5 19 12 12 19" />
                      </svg>
                    </span>
                  </div>
                </a>
              ))
            }
          </div>
        </div>
      </section>

      <!-- BUY / SELL SPLIT ─────────────────────────────────── -->
      <section id="buy-sell" class="bg-paper py-20 lg:py-28">
        <div class="mx-auto grid max-w-7xl gap-6 px-5 sm:px-8 lg:grid-cols-2">
          <a href="#contact" class="group relative overflow-hidden rounded-2xl bg-forest-800 p-9 text-cream lg:p-12">
            <div class="grain"></div>
            <span class="eyebrow text-gold-500">For Buyers & Investors</span>
            <h3 class="mt-4 font-display text-3xl font-medium lg:text-4xl">Buying in Bastrop</h3>
            <p class="mt-4 max-w-md text-cream/75">
              Retail space, industrial warehouses, development land — sourced, vetted, and
              underwritten so you move with confidence.
            </p>
            <span class="mt-8 inline-flex items-center gap-2 font-semibold text-gold-500">
              Explore buying
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-1"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </a>

          <a href="#contact" class="group relative overflow-hidden rounded-2xl border border-sand bg-white p-9 lg:p-12">
            <span class="eyebrow text-terra-500">For Sellers</span>
            <h3 class="mt-4 font-display text-3xl font-medium text-ink lg:text-4xl">Selling in Bastrop</h3>
            <p class="mt-4 max-w-md text-stone">
              Strategic marketing, professional valuation, and negotiation expertise to put
              your commercial property in front of the right buyer.
            </p>
            <span class="mt-8 inline-flex items-center gap-2 font-semibold text-terra-500">
              Explore selling
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-1"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </a>
        </div>
      </section>

      <!-- MEET THE AGENT ───────────────────────────────────── -->
      <section id="agent" class="relative overflow-hidden bg-forest-900 py-20 text-cream lg:py-28">
        <div class="grain"></div>
        <div class="relative mx-auto grid max-w-7xl items-center gap-12 px-5 sm:px-8 lg:grid-cols-[0.85fr_1fr] lg:gap-16">
          <div class="relative mx-auto w-full max-w-sm">
            <div class="aspect-[4/5] w-full overflow-hidden rounded-2xl bg-gradient-to-br from-forest-700 via-forest-800 to-forest-950">
              <img
                src={agentImage}
                alt={`${site.agent.name}, ${site.agent.title}`}
                loading="lazy"
                decoding="async"
                class="h-full w-full object-cover"
                onerror="this.style.opacity='0'"
              />
            </div>
            <div class="absolute -bottom-5 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-full bg-gold-500 px-6 py-2.5 font-display text-sm font-semibold text-forest-950 shadow-lg">
              {site.agent.name} · {site.agent.title}
            </div>
          </div>

          <div>
            <span class="eyebrow block text-gold-500">Meet Your Agent</span>
            <h2 class="mt-3 font-display text-3xl font-medium leading-[1.05] text-cream sm:text-4xl md:text-[2.75rem]">
              Grounded expertise, end to end.
            </h2>
            <p class="mt-6 text-lg leading-relaxed text-cream/80">{site.agent.bio}</p>
            <div class="mt-8 flex flex-wrap items-center gap-4">
              <a href="#contact" class="btn btn-gold">Work with {site.agent.name.split(" ")[0]}</a>
              <a href={site.agent.phoneHref} class="link-underline text-cream/80">{site.agent.phone}</a>
            </div>
          </div>
        </div>
      </section>

      <!-- CONTACT ──────────────────────────────────────────── -->
      <section id="contact" class="bg-cream py-20 lg:py-28">
        <div class="mx-auto grid max-w-6xl items-start gap-14 px-5 sm:px-8 lg:grid-cols-2">
          <div>
            <span class="eyebrow block text-terra-500">Get in Touch</span>
            <h2 class="mt-3 font-display text-3xl font-medium leading-[1.05] text-ink sm:text-4xl md:text-[2.75rem]">
              Let's talk about your next move.
            </h2>
            <p class="mt-6 text-lg leading-relaxed text-stone">
              Whether you're acquiring land, selling a commercial asset, or just want a candid
              read on the Bastrop market — reach out and let's start the conversation.
            </p>
            <dl class="mt-10 space-y-5">
              <div>
                <dt class="eyebrow text-terra-500">Call</dt>
                <dd class="mt-1 font-display text-2xl text-ink"><a href={site.agent.phoneHref} class="link-underline">{site.agent.phone}</a></dd>
              </div>
              <div>
                <dt class="eyebrow text-terra-500">Email</dt>
                <dd class="mt-1 font-display text-2xl text-ink"><a href={`mailto:${site.agent.email}`} class="link-underline">{site.agent.email}</a></dd>
              </div>
            </dl>
          </div>

          <div class="rounded-2xl border border-sand bg-white p-7 shadow-[0_20px_50px_-30px_rgba(40,30,10,0.5)] sm:p-9">
            <!--
              Static-site submission: wire `action` to your provider when hosting is chosen.
                • Netlify Forms — add `data-netlify="true"` and a hidden form-name input.
                • Formspree     — set action="https://formspree.io/f/XXXX".
              Until then it posts nowhere; the markup + validation are production-ready.
            -->
            <form action="#" method="POST" class="space-y-5">
              <div class="grid gap-5 sm:grid-cols-2">
                <div>
                  <label class="eyebrow mb-2 block text-forest-800" for="firstName">First name</label>
                  <input id="firstName" name="firstName" type="text" required autocomplete="given-name"
                    class="w-full rounded-lg border border-sand bg-transparent px-4 py-3 text-sm text-ink transition-colors placeholder:text-stone/60 focus:outline-none focus:ring-2 focus:ring-gold-500/60" placeholder="Jane" />
                </div>
                <div>
                  <label class="eyebrow mb-2 block text-forest-800" for="lastName">Last name</label>
                  <input id="lastName" name="lastName" type="text" required autocomplete="family-name"
                    class="w-full rounded-lg border border-sand bg-transparent px-4 py-3 text-sm text-ink transition-colors placeholder:text-stone/60 focus:outline-none focus:ring-2 focus:ring-gold-500/60" placeholder="Doe" />
                </div>
              </div>

              <div class="grid gap-5 sm:grid-cols-2">
                <div>
                  <label class="eyebrow mb-2 block text-forest-800" for="email">Email</label>
                  <input id="email" name="email" type="email" required autocomplete="email"
                    class="w-full rounded-lg border border-sand bg-transparent px-4 py-3 text-sm text-ink transition-colors placeholder:text-stone/60 focus:outline-none focus:ring-2 focus:ring-gold-500/60" placeholder="jane@company.com" />
                </div>
                <div>
                  <label class="eyebrow mb-2 block text-forest-800" for="phone">Phone</label>
                  <input id="phone" name="phone" type="tel" autocomplete="tel"
                    class="w-full rounded-lg border border-sand bg-transparent px-4 py-3 text-sm text-ink transition-colors placeholder:text-stone/60 focus:outline-none focus:ring-2 focus:ring-gold-500/60" placeholder="(512) 555-0100" />
                </div>
              </div>

              <div>
                <label class="eyebrow mb-2 block text-forest-800" for="interest">I'm interested in</label>
                <select id="interest" name="interest"
                  class="w-full appearance-none rounded-lg border border-sand bg-transparent px-4 py-3 text-sm text-ink transition-colors focus:outline-none focus:ring-2 focus:ring-gold-500/60">
                  <option>Buying / investing in Bastrop</option>
                  <option>Selling commercial property</option>
                  <option>A specific listing</option>
                  <option>Market consultation</option>
                </select>
              </div>

              <div>
                <label class="eyebrow mb-2 block text-forest-800" for="message">Message</label>
                <textarea id="message" name="message" rows="4" required
                  class="w-full resize-y rounded-lg border border-sand bg-transparent px-4 py-3 text-sm text-ink transition-colors placeholder:text-stone/60 focus:outline-none focus:ring-2 focus:ring-gold-500/60"
                  placeholder="Tell me a little about what you're looking for…"></textarea>
              </div>

              <button type="submit" class="btn btn-forest w-full justify-center">Send message</button>

              <p class="text-center text-xs text-stone">
                Prefer to talk? Call <a href={site.agent.phoneHref} class="link-underline font-semibold">{site.agent.phone}</a>
              </p>
            </form>
          </div>
        </div>
      </section>
    </main>

    <!-- FOOTER ─────────────────────────────────────────────── -->
    <footer class="relative overflow-hidden bg-forest-950 text-cream">
      <div class="grain"></div>
      <div class="relative mx-auto max-w-7xl px-5 py-16 sm:px-8 lg:py-20">
        <div class="grid gap-12 md:grid-cols-[1.4fr_1fr_1fr]">
          <div>
            <div class="flex items-center gap-2.5">
              <span class="grid h-9 w-9 place-items-center rounded-md bg-gold-500 font-display text-lg font-semibold text-forest-950">B</span>
              <span class="font-display text-lg font-semibold">{site.longName}</span>
            </div>
            <p class="mt-5 max-w-sm text-sm leading-relaxed text-cream/70">{site.description}</p>
            <a href="#contact" class="btn btn-gold mt-7">Book a consultation</a>
          </div>

          <div>
            <h3 class="eyebrow text-gold-500">Explore</h3>
            <ul class="mt-5 space-y-3 text-sm text-cream/80">
              {nav.map((item) => (
                <li><a href={item.href} class="link-underline">{item.label}</a></li>
              ))}
            </ul>
          </div>

          <div>
            <h3 class="eyebrow text-gold-500">Contact</h3>
            <ul class="mt-5 space-y-3 text-sm text-cream/80">
              <li class="font-display text-lg text-cream">{site.agent.name}</li>
              <li>{site.agent.title} · {site.agent.brokerage}</li>
              <li><a href={site.agent.phoneHref} class="link-underline">{site.agent.phone}</a></li>
              <li><a href={`mailto:${site.agent.email}`} class="link-underline">{site.agent.email}</a></li>
            </ul>
          </div>
        </div>

        <div class="mt-14 flex flex-col gap-2 border-t border-cream/10 pt-7 text-xs text-cream/50 sm:flex-row sm:items-center sm:justify-between">
          <p>© {year} {site.longName}. All rights reserved.</p>
          <p>{site.agent.name}, {site.agent.title} with {site.agent.brokerage}. Equal Housing Opportunity.</p>
        </div>
      </div>
    </footer>

    <style>
      .site-header { background: transparent; }
      .site-header.scrolled {
        background: color-mix(in srgb, var(--color-forest-900) 92%, transparent);
        -webkit-backdrop-filter: blur(10px);
        backdrop-filter: blur(10px);
        box-shadow: 0 8px 30px -12px rgba(0, 0, 0, 0.5);
      }
    </style>

    <script>
      const header = document.querySelector(".site-header");
      const onScroll = () => {
        if (window.scrollY > 40) header?.classList.add("scrolled");
        else header?.classList.remove("scrolled");
      };
      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });

      const menu = document.getElementById("mobile-menu");
      const toggle = document.getElementById("menu-toggle");
      const close = document.getElementById("menu-close");
      const open = () => {
        menu?.classList.remove("hidden");
        toggle?.setAttribute("aria-expanded", "true");
        document.body.style.overflow = "hidden";
      };
      const shut = () => {
        menu?.classList.add("hidden");
        toggle?.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";
      };
      toggle?.addEventListener("click", open);
      close?.addEventListener("click", shut);
      menu?.querySelectorAll("a").forEach((a) => a.addEventListener("click", shut));
    </script>
  </body>
</html>
