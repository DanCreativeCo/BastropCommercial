---
import "../styles/global.css";
import { site } from "../lib/site";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  /** Transparent header that sits over a dark hero (home, listing detail). */
  transparentHeader?: boolean;
}

const {
  title,
  description = site.description,
  transparentHeader = false,
} = Astro.props;

const fullTitle = title ? `${title} · ${site.longName}` : `${site.longName} — ${site.tagline}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={site.longName} />
    <meta name="theme-color" content="#16291c" />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:rounded-md focus:bg-forest-800 focus:px-4 focus:py-2 focus:text-cream"
      >Skip to content</a
    >
    <Header transparent={transparentHeader} />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
